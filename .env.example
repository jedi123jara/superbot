# ================================
# ALPACA CREDENTIALS
# ================================
# Obtén tus keys en: https://app.alpaca.markets/paper-trading/overview
ALPACA_API_KEY=TU_API_KEY_AQUI
ALPACA_SECRET_KEY=TU_SECRET_KEY_AQUI
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ================================
# BOT BEHAVIOR
# ================================
# true = el bot arranca automáticamente al desplegar en Koyeb
AUTO_RUN=true

# ================================
# PARÁMETROS DEL BOT
# ================================
CAPITAL_INICIAL=1000.0
RIESGO_PCT=0.10
TAKE_PROFIT_PCT=0.03
STOP_LOSS_PCT=0.003
DIAS_HISTORICO=365
